# URL da aplicação (usada para links de confirmação no WhatsApp)
# Configure com a URL de produção (ex: https://meusite.vercel.app)
# Se não configurado, usará window.location.origin (pode falhar em localhost)
VITE_APP_URL=http://localhost:5173

# Supabase Configuration
# 1. Copie este arquivo para .env.local (na raiz do projeto)
# 2. No painel Supabase: Project Settings > API > Project URL e anon public key
# 3. Cole a URL e a chave abaixo. Sem isso o login dá "Failed to fetch".

# Supabase Project URL
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Supabase Anon/Public Key (Supabase > Settings > API > anon public)
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Opcional: Service Role (NUNCA commitar)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Hotmart Integration - Página de pagamento para assinaturas
VITE_HOTMART_CHECKOUT_URL=https://pay.hotmart.com/O104666619F?bid=1772219819580

# Vídeo na página de vendas (ID do YouTube, ex: dQw4w9WgXcQ da URL youtube.com/watch?v=dQw4w9WgXcQ)
# VITE_LANDING_VIDEO_ID=
# VITE_HOTMART_SECRET_TOKEN=seu_token_secreto_aqui

# Push Notifications (para notificações com app fechado)
# Gerar chaves: npx web-push generate-vapid-keys
# Cole a Public Key abaixo; a Private Key fica no servidor (Edge Function, etc.)
VITE_VAPID_PUBLIC_KEY=BNhH_qaRooVuN6PhgxNOTq1SPcnnCu5Wca3Ak8kZkKluDbWsE-3RIxJKE1hxyjVBtW_gqMR2-Qfijz7AIliPC3Q
